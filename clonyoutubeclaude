<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>YouTube</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0f0f0f;
    --surface: #212121;
    --surface2: #272727;
    --border: #3f3f3f;
    --text: #f1f1f1;
    --text-muted: #aaa;
    --red: #ff0000;
    --chip-bg: #3f3f3f;
    --chip-active: #f1f1f1;
    --chip-active-text: #0f0f0f;
    --sidebar-w: 240px;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Roboto', Arial, sans-serif;
    font-size: 14px;
    overflow-x: hidden;
  }

  /* ── TOPBAR ── */
  header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    height: 56px;
    background: var(--bg);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 16px;
    border-bottom: 1px solid #1f1f1f;
  }

  .header-left { display: flex; align-items: center; gap: 16px; }

  .menu-btn {
    width: 40px; height: 40px; border-radius: 50%;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 5px;
    cursor: pointer; background: none; border: none; padding: 8px;
  }
  .menu-btn span { display: block; width: 18px; height: 2px; background: var(--text); border-radius: 1px; }

  .logo { display: flex; align-items: center; gap: 2px; text-decoration: none; }
  .logo svg { height: 20px; }
  .logo-text { font-size: 20px; font-weight: 700; letter-spacing: -0.5px; color: var(--text); margin-left: 4px; }
  .logo-text span { color: var(--text-muted); font-weight: 400; font-size: 11px; vertical-align: super; margin-left: 1px; }

  .search-area { display: flex; align-items: center; gap: 8px; flex: 1; max-width: 640px; margin: 0 40px; }

  .search-bar {
    flex: 1; display: flex; align-items: center;
    border: 1px solid var(--border); border-radius: 40px 0 0 40px;
    overflow: hidden;
  }
  .search-bar input {
    flex: 1; padding: 8px 16px; background: var(--bg);
    border: none; outline: none; color: var(--text); font-size: 16px;
  }
  .search-bar input::placeholder { color: var(--text-muted); }

  .search-btn {
    width: 64px; height: 40px;
    background: var(--surface); border: 1px solid var(--border);
    border-left: none; border-radius: 0 40px 40px 0;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    color: var(--text);
  }
  .search-btn:hover { background: var(--surface2); }

  .mic-btn {
    width: 40px; height: 40px; border-radius: 50%;
    background: var(--surface2); border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center; color: var(--text);
    flex-shrink: 0;
  }

  .header-right { display: flex; align-items: center; gap: 8px; }

  .icon-btn {
    width: 40px; height: 40px; border-radius: 50%;
    background: none; border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    color: var(--text); position: relative;
  }
  .icon-btn:hover { background: var(--surface2); }

  .badge {
    position: absolute; top: 4px; right: 4px;
    background: var(--red); color: #fff;
    font-size: 10px; font-weight: 700;
    width: 16px; height: 16px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }

  .sign-in-btn {
    display: flex; align-items: center; gap: 8px;
    padding: 6px 14px; border-radius: 20px;
    border: 1px solid #3ea6ff; background: none;
    color: #3ea6ff; font-size: 14px; cursor: pointer;
    white-space: nowrap;
  }
  .sign-in-btn:hover { background: rgba(62,166,255,0.1); }

  /* ── SIDEBAR ── */
  aside {
    position: fixed; top: 56px; left: 0; bottom: 0;
    width: var(--sidebar-w);
    background: var(--bg);
    overflow-y: auto; overflow-x: hidden;
    padding: 12px 0;
    z-index: 90;
  }
  aside::-webkit-scrollbar { width: 4px; }
  aside::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .sidebar-item {
    display: flex; align-items: center; gap: 24px;
    padding: 0 24px; height: 40px;
    border-radius: 10px; margin: 0 4px;
    cursor: pointer; text-decoration: none; color: var(--text);
    transition: background 0.15s;
    white-space: nowrap;
  }
  .sidebar-item:hover { background: var(--surface2); }
  .sidebar-item.active { background: var(--surface); font-weight: 600; }
  .sidebar-item svg { flex-shrink: 0; }
  .sidebar-item span { font-size: 14px; }

  .sidebar-divider {
    height: 1px; background: var(--border);
    margin: 12px 0;
  }

  .sidebar-section-title {
    padding: 8px 24px; font-size: 14px; font-weight: 600;
    color: var(--text);
  }

  /* ── MAIN ── */
  main {
    margin-left: var(--sidebar-w);
    margin-top: 56px;
    padding: 0 24px 40px;
  }

  /* ── CHIPS ── */
  .chips-bar {
    position: sticky; top: 56px; z-index: 80;
    background: var(--bg);
    display: flex; gap: 12px; overflow-x: auto;
    padding: 12px 0;
    scrollbar-width: none;
  }
  .chips-bar::-webkit-scrollbar { display: none; }

  .chip {
    padding: 6px 14px; border-radius: 8px;
    background: var(--chip-bg); border: none;
    color: var(--text); font-size: 14px;
    cursor: pointer; white-space: nowrap;
    transition: background 0.15s;
  }
  .chip:hover { background: #4f4f4f; }
  .chip.active {
    background: var(--chip-active);
    color: var(--chip-active-text);
    font-weight: 600;
  }

  /* ── GRID ── */
  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px 16px;
    margin-top: 8px;
  }

  .video-card { cursor: pointer; }

  .thumbnail-wrap {
    position: relative;
    width: 100%; aspect-ratio: 16/9;
    border-radius: 12px; overflow: hidden;
    background: var(--surface);
  }
  .thumbnail-wrap img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.3s;
  }
  .video-card:hover .thumbnail-wrap img { transform: scale(1.03); }

  .duration {
    position: absolute; bottom: 6px; right: 6px;
    background: rgba(0,0,0,0.85); color: #fff;
    font-size: 12px; font-weight: 600; padding: 2px 5px;
    border-radius: 4px;
  }

  .progress-bar {
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 3px; background: rgba(255,255,255,0.3);
  }
  .progress-bar span {
    display: block; height: 100%; background: var(--red);
  }

  .video-info {
    display: flex; gap: 12px;
    padding: 10px 4px 0;
  }

  .avatar {
    width: 36px; height: 36px; border-radius: 50%;
    object-fit: cover; flex-shrink: 0;
    background: var(--surface2);
  }

  .video-meta { flex: 1; min-width: 0; }
  .video-title {
    font-size: 14px; font-weight: 600; line-height: 1.4;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden; color: var(--text);
  }
  .channel-name {
    color: var(--text-muted); font-size: 13px; margin-top: 4px;
    display: flex; align-items: center; gap: 4px;
  }
  .verified {
    width: 12px; height: 12px; background: var(--text-muted);
    border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .verified::after { content: '✓'; font-size: 8px; color: var(--bg); font-weight: 700; }
  .video-stats { color: var(--text-muted); font-size: 13px; margin-top: 2px; }

  .more-btn {
    background: none; border: none; color: var(--text-muted);
    cursor: pointer; padding: 4px; border-radius: 50%;
    opacity: 0; transition: opacity 0.15s;
    align-self: flex-start; margin-top: -2px;
    width: 24px; height: 24px;
  }
  .video-card:hover .more-btn { opacity: 1; }

  /* ── SHORTS ROW ── */
  .section-title { font-size: 18px; font-weight: 700; margin: 24px 0 12px; }

  .shorts-row {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 12px;
  }

  .short-card { cursor: pointer; }
  .short-thumb {
    aspect-ratio: 9/16;
    border-radius: 12px; overflow: hidden;
    background: var(--surface);
    position: relative;
  }
  .short-thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }
  .short-card:hover .short-thumb img { transform: scale(1.04); }
  .short-title {
    font-size: 14px; font-weight: 600; margin: 8px 4px 2px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .short-views { font-size: 13px; color: var(--text-muted); margin: 0 4px; }
  .short-badge {
    position: absolute; bottom: 8px; left: 8px;
    background: #ff0000; color: #fff;
    font-size: 11px; font-weight: 700;
    padding: 2px 7px; border-radius: 4px;
  }

  /* ── SVG ICONS ── */
  svg { fill: currentColor; }

  @media (max-width: 1200px) {
    .video-grid { grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); }
  }
  @media (max-width: 900px) {
    aside { display: none; }
    main { margin-left: 0; }
  }
  @media (max-width: 600px) {
    .search-area { margin: 0 12px; }
    .video-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
